# 优先修改这 3 项:
# TARGET_URL
# AUTH_PASSWORD
# SESSION_SECRET

# ===== 运行 =====

# 服务监听地址
LISTEN_ADDR=:8088

# 反向代理目标，本机网页地址
TARGET_URL=http://127.0.0.1:3000

# 如果前面还有一层可信代理，可打开以信任 X-Forwarded-For / X-Real-IP
TRUST_PROXY_HEADERS=false

# ===== 认证 =====

# 单密码登录密码
AUTH_PASSWORD=change-me

# Cookie 签名密钥，务必替换成长随机串
SESSION_SECRET=replace-with-a-long-random-secret

# 密码连续失败多少次后临时封禁，0 表示关闭
MAX_LOGIN_FAILURES=5

# 临时封禁时长
LOGIN_BAN_DURATION=15m

# ===== 会话状态 =====

# 认证会话存储后端：memory / file
# file 模式可在容器重启后保留已登录会话
AUTH_SESSION_STORE=file

# file 模式下的会话文件路径
# 如果直接运行二进制而不是 docker compose，请改成当前用户可写目录
AUTH_SESSION_FILE=/var/lib/0auth/auth-sessions.json

# 是否开启会话轮换
# 开启后，认证成功后的 Cookie 会按时间窗口滚动换代
AUTH_SESSION_ROTATION=true

# 当前代 Cookie 使用多久后自动换到下一代
AUTH_ROTATION_INTERVAL=5m

# 旧一代 Cookie 在换代后还能被短暂接受多久
# 主要用于多标签页、并发资源请求，避免正常刷新误伤
AUTH_ROTATION_GRACE=30s

# ===== Cookie =====

# Cookie 有效期，支持 30d / 720h / 12h
COOKIE_TTL=30d

# Cookie Secure 策略：auto / always / never
COOKIE_SECURE_MODE=auto

# 认证 Cookie 名
AUTH_COOKIE_NAME=rp_auth

# 语言偏好 Cookie 名
LANG_COOKIE_NAME=rp_lang

# ===== PoW =====

# PoW 难度，范围 0-64
# 0=关闭，2-3=轻量，4=常规，5=偏重，6=很重，7+=通常不适合真人用户
POW_DIFFICULTY=4

# 是否开启自动分级
# false=固定使用 POW_DIFFICULTY
# true=移动端降一级，可疑/自动化客户端升两级，并限制在最小/最大范围内
POW_AUTO_DIFFICULTY=false

# 自动分级启用哪些规则，按顺序匹配，命中第一条后即停止：
# empty-ua       空 User-Agent 加 1
# suspicious-ua  命中可疑 UA 子串列表加 2
# mobile         移动端减 1
POW_AUTO_RULES=empty-ua,suspicious-ua,mobile

# PoW 进度显示模式
# estimated=显示基于真实迭代次数的估算进度与真实指标
# fake=显示伪进度，不暴露真实尝试次数和速率
# hidden=只显示状态文字，不显示进度区
POW_PROGRESS_MODE=estimated

# 自动分级最小难度，仅在 POW_AUTO_DIFFICULTY=true 时生效
POW_MIN_DIFFICULTY=2

# 自动分级最大难度，仅在 POW_AUTO_DIFFICULTY=true 时生效
POW_MAX_DIFFICULTY=6

# suspicious-ua 规则使用的 User-Agent 子串列表，逗号分隔，大小写不敏感
# 只有 POW_AUTO_RULES 中包含 suspicious-ua 时才会用到
POW_SUSPICIOUS_UA_TOKENS=bot,spider,crawler,curl,wget,python-requests,go-http-client,headless,playwright,selenium,phantomjs,scrapy,postmanruntime,httpie,libwww-perl,aiohttp

# PoW 挑战有效期
POW_CHALLENGE_TTL=5m

# ===== i18n =====

# 默认语言：zh 或 en
DEFAULT_LANG=zh

# 按 IP 段决定默认语言，格式：CIDR=lang,CIDR=lang
I18N_IP_LANG_RULES=127.0.0.0/8=zh,::1/128=zh,10.0.0.0/8=zh,172.16.0.0/12=zh,192.168.0.0/16=zh,fc00::/7=zh

# ===== 模块开关 =====

# 可关闭模块 ID:
# query-lang             通过 URL 参数 ?lang=zh/en 切换语言
# lang-cookie            读取语言偏好 Cookie
# ip-lang                按来源 IP 网段推断默认语言
# accept-language        按浏览器 Accept-Language 推断默认语言
# pow-login-guard        登录前执行浏览器 SHA-256 PoW
# password-attempt-limit 按来源 IP + User-Agent 统计失败次数并临时封禁
# 多个模块用逗号分隔，例如：ip-lang,accept-language
DISABLED_MODULES=
